## wearables app metadata.
## Write is admin/sc_admin only (self-managed + Cloud). Read is broad, and the
## data model is exported system-wide so dashboards (and any app) can use it.

[]
access = read : [ * ], write : [ admin, sc_admin ]

## Export the Wearables data model globally.
[datamodels]
export = system

[datamodels/Wearables]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

## Views/nav readable by all, editable by admin only.
[views]
export = system

## Shared person lookups — write-locked to admin/sc_admin, exported global so
## every vendor add-on's enrichment + all dashboards resolve them.
[transforms/wearable_identity_map]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/wearable_person_profile]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[lookups/wearable_identity_map.csv]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[lookups/wearable_person_profile.csv]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

## Device registry (device_id -> friendly name). Enrichment only; write-locked.
[transforms/wearable_device_profile]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[lookups/wearable_device_profile.csv]
access = read : [ * ], write : [ admin, sc_admin ]
export = system
