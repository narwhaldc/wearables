## wearables app metadata.
## Write is admin/sc_admin only (self-managed + Cloud). Read is broad, and the
## data model is exported system-wide so dashboards (and any app) can use it.

[]
access = read : [ * ], write : [ admin, sc_admin ]

## Export the Wearables data model globally.
[datamodels]
export = system

[datamodels/Wearables]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

## Views/nav readable by all, editable by admin only.
[views]
export = system

## Shared person/device registries — KV Store backed (collections.conf), write-locked
## to admin/sc_admin, exported global so every vendor add-on's enrichment + all
## dashboards resolve them. The KV collections (not CSVs) hold the data, so admin
## edits survive app upgrades.
[transforms/wearable_identity_map]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/wearable_person_profile]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[transforms/wearable_device_profile]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

## KV Store collections — read broad, WRITE locked to admin/sc_admin (this is the
## write-integrity gate: restricted users cannot outputlookup / REST-write these).
[collections/wearable_identity_map]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[collections/wearable_person_profile]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[collections/wearable_device_profile]
access = read : [ * ], write : [ admin, sc_admin ]
export = system

[macros]
export = system
